{
  "name": "invizi-ru",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "sass sass/style.sass css/new.css --style=expanded --no-source-map",
    "build:min": "sass sass/style.sass css/new.css --style=compressed --no-source-map",
    "watch": "sass --watch sass/style.sass:css/new.css --style=expanded --no-source-map"
  },
  "devDependencies": {
    "sass": "^1.69.0"
  }
}
